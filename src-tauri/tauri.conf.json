{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forge AI",
  "version": "1.0.0",
  "identifier": "dev.tushar.forgeai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge AI",
        "width": 1380,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Unified AI runtime and provider control center",
    "longDescription": "Manage local, remote, and cloud AI providers, monitor token usage and costs, benchmark models, and expose a unified developer workflow.",
    "copyright": "Copyright © 2026 Tushar",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
